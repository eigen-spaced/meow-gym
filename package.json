{
  "name": "meow-gym",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "An interactive, vimmer-friendly practice ground for the Emacs meow modal editor",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "verify": "esbuild test/verify.ts --bundle --format=esm --platform=node --outfile=node_modules/.cache/verify.mjs && node node_modules/.cache/verify.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
